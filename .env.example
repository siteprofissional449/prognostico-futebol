PORT=3000

# Local: use DB_* abaixo. Render: pode colar a Internal Database URL em DATABASE_URL (aí DB_* são ignorados).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=prognostico_futebol

# Primeira subida em produção: true / 1 / yes / on — cria tabelas. Depois false ou remova.
# DB_SYNC=false

# Render: true / 1 / yes / on se der erro "SSL required" na conexão
# DB_SSL=false
FOOTBALL_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
JWT_SECRET=smartgol-dev-secret
# E-mail de um usuário já cadastrado que vira admin ao subir a API (opcional)
ADMIN_EMAIL=