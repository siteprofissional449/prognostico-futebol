PORT=3000

# Local: use DB_* abaixo. Railway/Render: cole a URL pública do Postgres em DATABASE_URL (aí DB_* são ignorados).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
#
# SQLTools no Cursor (.vscode/settings.json): com DATABASE_URL no .env, no PowerShell:
#   npm run sqltools:railway-env -- --print-ps1 | Out-File railway-pg.ps1 -Encoding utf8
#   . .\railway-pg.ps1
#   cursor .
# Depois: ícone SQLTools → ligação "Railway PostgreSQL".

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=prognostico_futebol

# Primeira subida em produção: true / 1 / yes / on — cria tabelas. Depois false ou remova.
# DB_SYNC=false

# Render: true / 1 / yes / on se der erro "SSL required" na conexão
# DB_SSL=false
FOOTBALL_API_KEY=

# Job diário: gera prognósticos às 00:05 (fuso CRON_TZ; padrão America/Sao_Paulo)
# CRON_TZ=America/Sao_Paulo
# DISABLE_DAILY_PREDICTION_CRON=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Meta mínima de palpites por dia (lote IA + por jogo + preenchimento por odds); padrão no código: 35
# MIN_DAILY_PREDICTIONS=35
# Tamanho do lote enviado à OpenAI (opcional); padrão no código: 50 picks
# BATCH_MAX_MATCHES=120
# BATCH_MAX_PICKS=50
JWT_SECRET=smartgol-dev-secret
# E-mail de um usuário já cadastrado que vira admin ao subir a API (opcional)
ADMIN_EMAIL=

# Uso único (não commitar): npm run build && definir no shell ADMIN_BOOTSTRAP_EMAIL + ADMIN_BOOTSTRAP_PASSWORD && npm run bootstrap:admin

# Mercado Pago — token de produção ou teste (https://www.mercadopago.com.br/developers)
MERCADOPAGO_ACCESS_TOKEN=
# URL pública da API (HTTPS em produção) para o webhook: {API_PUBLIC_URL}/payments/mercadopago/webhook
API_PUBLIC_URL=http://localhost:3000
# URL do site (retorno Mercado Pago + CORS no browser). Vercel: https://seu-projeto.vercel.app
# Várias origens: separar por vírgula (ex.: produção + preview Vercel)
FRONTEND_URL=http://localhost:5173